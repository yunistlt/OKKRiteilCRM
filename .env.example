NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API Keys
RETAILCRM_API_KEY=your-retailcrm-key
RETAILCRM_URL=https://your-domain.retailcrm.ru
TELPHIN_APP_KEY=your-telphin-app-key
TELPHIN_APP_SECRET=your-telphin-app-secret

# AI-секретарь Телфина (узел «Интерактивная обработка» → /api/telphin/secretary)
TELPHIN_SECRETARY_TOKEN=secret-token-in-url       # проверяется как ?token=...
TELPHIN_FALLBACK_EXTENSION=                        # добавочный/группа оператора, если менеджер не найден
TELPHIN_TRANSFER_VAR=transferDestination          # имя переменной схемы для перевода
TELPHIN_TTS_VOICE=alena                            # голос синтеза
TELPHIN_TTS_LANG=ru-RU
TELPHIN_TTS_SPEED=1.0
