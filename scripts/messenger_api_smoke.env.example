# Required: choose one auth mode for the primary user
export MESSENGER_BASE_URL="https://your-deployed-domain.vercel.app"
export MESSENGER_BEARER_TOKEN="paste-primary-user-bearer-token-here"
export MESSENGER_LOGIN=""
export MESSENGER_PASSWORD=""
export MESSENGER_CHAT_ID="00000000-0000-0000-0000-000000000000"
export MESSENGER_FORBIDDEN_CHAT_ID="00000000-0000-0000-0000-000000000000"

# Optional automation controls
export MESSENGER_ENABLE_MUTATION_CHECKS="true"
export MESSENGER_TEST_MESSAGE_PREFIX="[messenger-api-smoke]"

# Optional two-user direct/group flow: choose bearer or login/password for the second user
export MESSENGER_SECOND_BEARER_TOKEN="paste-second-user-bearer-token-here"
export MESSENGER_SECOND_LOGIN=""
export MESSENGER_SECOND_PASSWORD=""
export MESSENGER_DIRECT_PARTICIPANT_ID="123"
export MESSENGER_GROUP_PARTICIPANT_IDS="123,456"
